generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String      @id @default(cuid())
  name      String
  inventory Inventory[]
}

model Warehouse {
  id        String      @id @default(cuid())
  name      String
  inventory Inventory[]
}

model Inventory {
  id             String        @id @default(cuid())
  productId      String
  warehouseId    String
  totalStock     Int
  reservedStock  Int

  product         Product      @relation(fields: [productId], references: [id])
  warehouse       Warehouse    @relation(fields: [warehouseId], references: [id])

  reservations    Reservation[]
}

model Reservation {
  id           String      @id @default(cuid())
  inventoryId  String
  quantity     Int
  status       String
  expiresAt    DateTime

  inventory    Inventory   @relation(fields: [inventoryId], references: [id])
}